<Window x:Class="WpfReportLauncher.Views.ConfirmExitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="終了の確認"
        Width="420" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        Background="LightGray">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="アプリケーションを終了しますか？"
                   FontSize="18" FontWeight="SemiBold" />

        <TextBlock Grid.Row="1"
                   Text="保存していない処理がないかご確認ください。"
                   Opacity="0.8" Margin="0,8,0,0"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="キャンセル"
                    Width="100" Margin="0,0,8,0" Padding="12,8"
                    Background="Blue"
                    Foreground="White"
                    IsCancel="True" Click="Cancel_Click"/>
            <Button Content="終了"
                    Width="100" Padding="12,8"
                    Background="Blue"
                    Foreground="White"
                    IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>

